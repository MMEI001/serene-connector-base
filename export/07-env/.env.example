# Environment template — vul zelf de waarden in
# Kopieer naar .env in de nieuwe app. GÉÉN echte waarden hier.

# ---- Supabase (nieuw project aanmaken op https://supabase.com) ----
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SERVICE_ROLE_KEY=
# alias die veel bibliotheken verwachten:
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=

# ---- Client-side (Vite exposes deze aan browser) ----
VITE_SUPABASE_URL=
VITE_SUPABASE_PUBLISHABLE_KEY=
VITE_SUPABASE_ANON_KEY=
VITE_SUPABASE_PROJECT_ID=

# ---- Lovable AI Gateway (alle LLM-calls) ----
LOVABLE_API_KEY=

# ---- Speech-to-Text ----
SPEECH_PROVIDER=openai
OPENAI_API_KEY=
# GOOGLE_APPLICATION_CREDENTIALS=  # alleen bij SPEECH_PROVIDER=google
# DEEPGRAM_API_KEY=                # alleen bij SPEECH_PROVIDER=deepgram

# ---- Text-to-Speech (ElevenLabs, in edge function) ----
ELEVENLABS_API_KEY=

# ---- Web-tak (optioneel: aanbiedingen/prijzen) ----
FIRECRAWL_API_KEY=

# ---- Google Calendar sync (optioneel) ----
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ---- Feature flags ----
ASSISTANT_FRAMEWORK=on
NODE_ENV=development
